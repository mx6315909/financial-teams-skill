# OpenClaw Gateway 环境变量配置
# 复制到 ~/.config/openclaw/gateway.env 并填入实际值

# ============================================
# 网关认证（必须设置）
# ============================================
OPENCLAW_GATEWAY_TOKEN=your-random-token-here

# 可选：指定端口（默认18789）
# OPENCLAW_GATEWAY_PORT=18789

# ============================================
# 模型 API Keys（按需启用）
# ============================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# BAILIAN_API_KEY=sk-sp-...

# ============================================
# 渠道配置（按需启用）
# ============================================
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...

# ============================================
# 自愈通知（可选）
# ============================================
# 修复时发送 Telegram 通知的目标 chat_id
# OPENCLAW_FIX_TELEGRAM_TARGET=123456789
